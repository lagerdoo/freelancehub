@model FreelanceHub.Web.ViewModels.Admin.ServiceFormViewModel

<partial name="_AdminBackButton" model="@Url.Action("Index", "Services", new { area = "Admin" })!" />

<div class="section-card">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="row g-3">
        <input asp-for="Id" type="hidden" />
        <div class="col-md-6">
            <label asp-for="TitleEn" class="form-label"></label>
            <input asp-for="TitleEn" class="form-control" />
            <span asp-validation-for="TitleEn" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="TitleFr" class="form-label"></label>
            <input asp-for="TitleFr" class="form-control" />
            <span asp-validation-for="TitleFr" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="SummaryEn" class="form-label"></label>
            <textarea asp-for="SummaryEn" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-md-6">
            <label asp-for="SummaryFr" class="form-label"></label>
            <textarea asp-for="SummaryFr" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-md-6">
            <label asp-for="DescriptionEn" class="form-label"></label>
            <textarea asp-for="DescriptionEn" class="form-control" rows="6"></textarea>
        </div>
        <div class="col-md-6">
            <label asp-for="DescriptionFr" class="form-label"></label>
            <textarea asp-for="DescriptionFr" class="form-control" rows="6"></textarea>
        </div>
        <div class="col-md-4">
            <label asp-for="IconClass" class="form-label"></label>
            <input asp-for="IconClass" class="form-control" />
            <div class="form-text text-secondary">Used on the public Services section and previewed below.</div>
            <div class="icon-preview mt-3">
                <span class="icon-pill"><i id="service-icon-preview" class="@Model.IconClass"></i></span>
            </div>
        </div>
        <div class="col-md-4">
            <label asp-for="ImagePath" class="form-label"></label>
            <input asp-for="ImagePath" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="DisplayOrder" class="form-label"></label>
            <input asp-for="DisplayOrder" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="Slug" class="form-label"></label>
            <input asp-for="Slug" class="form-control" />
        </div>
        <div class="col-12 form-check">
            <input asp-for="IsPublished" class="form-check-input" />
            <label asp-for="IsPublished" class="form-check-label"></label>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-accent">Save service</button>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
