<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@((ViewBag.AdminPageTitle as string ?? "Admin") + " | FreelanceHub Admin")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
</head>
<body>
    <div class="container-fluid py-4">
        <div class="admin-shell rounded-5">
            <div class="row g-0">
                <aside class="col-xl-2 admin-sidebar d-none d-xl-block">
                    <div class="p-4 h-100">
                        <partial name="_AdminNav" />
                    </div>
                </aside>
                <main class="col-12 col-xl-10">
                    <div class="p-4 p-lg-5">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
                            <div>
                                <button class="btn btn-outline-light d-xl-none mb-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminMobileNav" aria-controls="adminMobileNav">
                                    <i class="fa-solid fa-bars me-2"></i>Menu
                                </button>
                                <p class="eyebrow mb-1">Administration</p>
                                <h1 class="mb-0">@((ViewBag.AdminPageTitle as string) ?? "Dashboard")</h1>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <span class="text-secondary">@User.Identity.Name</span>
                                    <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="btn btn-outline-light">Logout</button>
                                    </form>
                                }
                            </div>
                        </div>
                        @if (TempData["AdminSuccess"] is string adminSuccess)
                        {
                            <div class="alert alert-success border-0">@adminSuccess</div>
                        }
                        @if (TempData["AdminError"] is string adminError)
                        {
                            <div class="alert alert-danger border-0">@adminError</div>
                        }
                        @RenderBody()
                    </div>
                </main>
            </div>
        </div>
    </div>
    <div class="offcanvas offcanvas-start admin-mobile-nav" tabindex="-1" id="adminMobileNav" aria-labelledby="adminMobileNavLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="adminMobileNavLabel">FreelanceHub</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <partial name="_AdminNav" />
        </div>
    </div>
    <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content admin-modal">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Confirm deletion</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-secondary" id="deleteConfirmMessage">This item will be permanently deleted.</div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteButton">Delete</button>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
