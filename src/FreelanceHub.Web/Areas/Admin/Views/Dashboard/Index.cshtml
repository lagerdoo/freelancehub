@model FreelanceHub.Web.ViewModels.Admin.DashboardViewModel

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="section-card h-100">
            <p class="eyebrow">Services</p>
            <h2>@Model.Summary.PublishedServices</h2>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="section-card h-100">
            <p class="eyebrow">Projects</p>
            <h2>@Model.Summary.PublishedProjects</h2>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="section-card h-100">
            <p class="eyebrow">Experience</p>
            <h2>@Model.Summary.VisibleExperienceEntries</h2>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="section-card h-100">
            <p class="eyebrow">Unread messages</p>
            <h2>@Model.Summary.UnreadContactMessages</h2>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Recent contact messages</h3>
        <a asp-area="Admin" asp-controller="ContactMessages" asp-action="Index" class="btn btn-outline-light">Open inbox</a>
    </div>
    <div class="table-responsive">
        <table class="table table-dark align-middle mb-0 admin-table">
            <thead>
                <tr>
                    <partial name="_SortableHeader" model='new AdminSortHeaderViewModel { Label = "Name", SortKey = "name", SortState = Model.RecentMessagesTable.SortState, Href = Url.Action("Index", new { sort = "name", dir = Model.RecentMessagesTable.SortState.GetNextDirection("name") })! }' />
                    <partial name="_SortableHeader" model='new AdminSortHeaderViewModel { Label = "Subject", SortKey = "subject", SortState = Model.RecentMessagesTable.SortState, Href = Url.Action("Index", new { sort = "subject", dir = Model.RecentMessagesTable.SortState.GetNextDirection("subject") })! }' />
                    <partial name="_SortableHeader" model='new AdminSortHeaderViewModel { Label = "Date", SortKey = "date", SortState = Model.RecentMessagesTable.SortState, Href = Url.Action("Index", new { sort = "date", dir = Model.RecentMessagesTable.SortState.GetNextDirection("date") })! }' />
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var message in Model.RecentMessagesTable.Items)
                {
                    <tr class="clickable-row" data-href="@Url.Action("Details", "ContactMessages", new { area = "Admin", id = message.Id })" tabindex="0">
                        <td>@message.Name</td>
                        <td>@message.Subject</td>
                        <td>@message.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                        <td class="text-end"><i class="fa-solid fa-chevron-right text-secondary"></i></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
