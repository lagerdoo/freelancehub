@model AdminListPageViewModel<Project>

<div class="d-flex justify-content-end mb-3">
    <a asp-action="Create" class="btn btn-accent">New project</a>
</div>

<div class="section-card">
    <div class="table-responsive">
        <table class="table table-dark align-middle mb-0 admin-table">
            <thead>
                <tr>
                    <partial name="_SortableHeader" model='new AdminSortHeaderViewModel { Label = "English title", SortKey = "titleEn", SortState = Model.SortState, Href = Url.Action("Index", new { sort = "titleEn", dir = Model.SortState.GetNextDirection("titleEn") })! }' />
                    <partial name="_SortableHeader" model='new AdminSortHeaderViewModel { Label = "Featured", SortKey = "featured", SortState = Model.SortState, Href = Url.Action("Index", new { sort = "featured", dir = Model.SortState.GetNextDirection("featured") })! }' />
                    <partial name="_SortableHeader" model='new AdminSortHeaderViewModel { Label = "Order", SortKey = "order", SortState = Model.SortState, Href = Url.Action("Index", new { sort = "order", dir = Model.SortState.GetNextDirection("order") })! }' />
                    <partial name="_SortableHeader" model='new AdminSortHeaderViewModel { Label = "Status", SortKey = "status", SortState = Model.SortState, Href = Url.Action("Index", new { sort = "status", dir = Model.SortState.GetNextDirection("status") })! }' />
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr class="clickable-row" data-href="@Url.Action("Edit", new { id = item.Id })" tabindex="0">
                        <td>@item.TitleEn</td>
                        <td>@(item.IsFeatured ? "Yes" : "No")</td>
                        <td>@item.DisplayOrder</td>
                        <td>@(item.IsPublished ? "Published" : "Draft")</td>
                        <td class="text-end">
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline row-action-form">
                                <button type="submit"
                                        class="btn btn-sm btn-icon btn-outline-danger"
                                        data-delete-confirm="true"
                                        data-delete-message="Delete this project permanently?">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
