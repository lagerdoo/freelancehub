{
  "ConnectionStrings": {
    "Sqlite": "Data Source=App_Data/freelancehub.db"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "ContactForm": {
    "MinimumSubmitDelaySeconds": 3,
    "TokenLifetimeHours": 12,
    "MaxSubmissionsPerWindow": 3,
    "RateLimitWindowMinutes": 15
  },
  "Uploads": {
    "MaxFileSizeBytes": 3145728
  },
  "Smtp": {
    "Enabled": false,
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "UseSsl": true,
    "FromEmail": "",
    "FromName": "FreelanceHub"
  },
  "Seeding": {
    "EnableDemoContent": true
  },
  "SeedAdmin": {
    "Username": "admin",
    "Email": "admin@localhost",
    "DisplayName": "Site Administrator"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
