{
  "Database": {
    "Provider": "PostgreSql"
  },
  "Smtp": {
    "Enabled": true
  },
  "CvImport": {
    "MaxFileSizeBytes": 5242880,
    "StorageFolder": "App_Data/CvImports"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Seeding": {
    "EnableDemoContent": false
  }
}
